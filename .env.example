# Model API Keys
OPENROUTER_API_KEY=
COHERE_API_KEY=
CLAUDE_API_KEY=
KIMI_API_KEY=

# API Base URLs
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OLLAMA_API_BASE=http://localhost:11434
KIMI_API_BASE=https://api.kimi.ai
CLAUDE_API_BASE=https://api.anthropic.com
COHERE_API_BASE=https://api.cohere.ai
HUGGINGFACE_API_BASE=https://api-inference.huggingface.co

# Model Configuration
DEFAULT_CONTEXT_LENGTH=4096
ENABLE_MODEL_FALLBACK=true
MAX_RETRIES=3

# Role-specific Settings
TECH_LEAD_MIN_CONTEXT=8192
AGENT_ARCHITECT_MIN_CONTEXT=16384

# Metrics and Monitoring
ENABLE_USAGE_TRACKING=true
METRICS_EXPORT_PATH=./metrics

# KIMI API Configuration
KIMI2_MODEL_VERSION=latest
KIMI2_MAX_TOKENS=32768
KIMI2_TEMPERATURE=0.7

# Model Selection
DEFAULT_CODING_MODEL=kimi2
ENABLE_MODEL_FALLBACK=true
